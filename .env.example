# GitHub Pages repo path. Example: /guesscue/
VITE_BASE_PATH=/

# Optional Supabase live room mode.
# VITE_SUPABASE_ANON_KEY is designed for browser use and respects Row Level Security.
# Never put a service_role key in frontend code or in a public repository.
VITE_SUPABASE_ENABLED=false
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
